# ============================================================
# MediChain - Cloud database credentials
# Copy this file to `.env` (no extension) and fill in values from
# your free MySQL provider. Do NOT commit .env to git.
# ============================================================

# Hostname given by the provider (e.g. something.aivencloud.com)
DB_HOST=

# Port (Aiven usually uses a custom port like 15432; most others use 3306)
DB_PORT=

# Database/schema name (often fixed per provider — e.g. "defaultdb")
DB_NAME=defaultdb

# Database username
DB_USERNAME=

# Database password
DB_PASSWORD=
